@model Models.Media

<div class="detailsPanel">
	<dl>
		@if (!Model.Shared && !Models.User.ConnectedUser.IsAdmin && Model.OwnerId != Models.User.ConnectedUser.Id)
		{
			<dd>
				<span style="color:red">Cette vidéo n'est pas partagé...</span>
			</dd>
		}
		else
		{
			<dd>
				@if (Model.Shared && (Model.OwnerId == Models.User.ConnectedUser.Id || Models.User.ConnectedUser.IsAdmin))
				{
					<span style="color:grey">[Partagé]</span>
				}
			</dd>

			<dd>@Model.Title</dd>
			<dd>@Helper.YoutubePlayer(Model.YoutubeId)</dd>
			<dd class="description">@Model.Description</dd>

			<dt>Catégorie</dt>
			<dd>@Model.Category</dd>

			<dt>Date de publication</dt>
			<dd>@Helper.When(Model.PublishDate)</dd>

			<dt>Propriétaire</dt>
			<dd class="owner">
				@Helper.AvatarUser(Model.Owner)
			</dd>
		}
	</dl>
</div>