@model Models.Media
@{
    ViewBag.PageTitle = "Détails";
    string search = Session["Search"] != null ? ((bool)Session["Search"]).ToString() : false.ToString();
    string SearchString = Session["SearchString"] != null ? (string)Session["SearchString"] : "";
}

<div id="detailsPanel" class="detailsPanel">
    <!-- auto refreshed -->
</div>

@section Scripts {
	<script>
        $(() => {
            newSession(600);
            mediaDetails_ARP = new AutoRefreshedPanel("detailsPanel", "/Medias/GetMediaDetails", 5, mediaDetailsPostRefresh);
            sessionStorage.setItem("RestoreScrollPosition", "1");
            Likes_ARPanel = new AutoRefreshedPanel("LikesPanel", "/Medias/RefreshLikeHeader/@Model.Id", 5);
        })

		/*function refreshLikeHeader(mediaId) {
			$("#likeHeaderContainer").load("/Medias/RefreshLikeHeader/" + mediaId);
		}*/
        function mediaDetailsPostRefresh(fromRefresh = true) {
            /*if (fromRefresh) {
                $(document).off("click", ".toggleLikeCmd").on("click", ".toggleLikeCmd", function (e) {
                    e.preventDefault();
					mediaDetails_ARP.command("/Medias/ToggleMediaLike/" + $(this).attr("mediaid");
					refreshLikeHeader($(this).attr("mediaid"));
                });
            }*/
            highlightKeyword();
        }

        function highlightKeyword() {
            if ("@search" == "True") {
                let keyword = "@SearchString";
                if (keyword.length > 0) {
                     let titles = document.getElementsByClassName('mediaTitle');
                     Array.from(titles).forEach(title => {
                         highlight(keyword, title);
                     });
                     let descriptions = document.getElementsByClassName('mediaDescription');
                     Array.from(descriptions).forEach(description => {
                         highlight(keyword, description);
                     })
                }
            }
        }
	</script>
}